{
  "permissions": {
    "allow": [
      "Edit(~/.claude/commands/mid-student3/**)",
      "Bash(python3 -c ' *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/brandon/Claude/Projects/.claude/hooks/pre-tool-guard.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/skill-source-reminder.py\""
          },
          {
            "type": "command",
            "command": "python3 -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/edit-restriction-hook.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/factcheck-numbers.py\""
          },
          {
            "type": "command",
            "command": "python3 -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/quality-loop-enforcer.py\""
          },
          {
            "type": "command",
            "command": "python3 -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/fact-loop-enforcer.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-git-pull.py\""
          }
        ]
      }
    ]
  }
}