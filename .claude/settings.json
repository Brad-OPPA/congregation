{
  "permissions": {
    "allow": [
      "Edit(~/.claude/commands/mid-student3/**)",
      "Bash(python3 -c ' *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-on-edit-write.py\""
          }
        ]
      },
      {
        "matcher": "Task|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-on-task-call.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-canonical-dropbox.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-on-task-call.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-git-pull.py\""
          }
        ]
      }
    ]
  }
}
